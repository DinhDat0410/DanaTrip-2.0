# Sao chép thành file .env và điền giá trị từ cổng MoMo (sandbox / production).

MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=

# Endpoint sandbox (mặc định test):
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create

# URL frontend sau khi thanh toán (GET, MoMo redirect về đây):
MOMO_REDIRECT_URL=http://localhost:5173/payment/momo-return

# URL backend nhận IPN (POST). Localhost MoMo không gọi được — cần URL public (vd. ngrok) khi test IPN:
MOMO_IPN_URL=https://your-public-domain.com/api/payment/momo-ipn
